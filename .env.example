# Copia este archivo como .env y ajusta si hace falta.
#
# Opción A (recomendada) — Base de datos con Docker (docker-compose.yml):
DATABASE_URL="postgresql://secureperu:secureperu@localhost:5435/secureperu?schema=public"
#
# Opción B — Postgres instalado localmente: reemplaza usuario, contraseña y
# puerto por los tuyos, por ejemplo:
# DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/secureperu?schema=public"
